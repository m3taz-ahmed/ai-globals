{
  "permissions": {
    "allow": [
      "view",
      "Read",
      "grep",
      "Glob",
      "bash:git status",
      "bash:git diff",
      "bash:git log",
      "bash:ls",
      "bash:cd",
      "bash:pwd",
      "bash:graphify"
    ],
    "ask": [
      "edit",
      "write",
      "Bash",
      "bash:rm",
      "bash:mv",
      "bash:cp",
      "mcp_call_tool",
      "mcp_read_resource"
    ],
    "deny": [
      "bash:rm -rf",
      "bash:git reset --hard",
      "bash:git checkout .",
      "bash:git clean -fd",
      "bash:git add -A",
      "bash:git add .",
      "bash:git push -f",
      "bash:git stash",
      "bash:curl -X POST",
      "bash:curl -X DELETE",
      "bash:Invoke-WebRequest -Method Post",
      "bash:Invoke-WebRequest -Method Delete",
      "bash:node -e",
      "bash:python -c"
    ]
  },
  "mcpServers": {
    "ai-global-os": {
      "command": "python",
      "args": [
        "-c",
        "import os,sys,subprocess,pathlib; root=os.environ.get('AGENT_OS_ROOT') or str(pathlib.Path.home()/'.ai-os'); subprocess.run([sys.executable,'-m','aios_mcp.aios_server'], cwd=root)"
      ]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@context7/mcp"]
    },
    "graphify": {
      "command": "python",
      "args": [
        "-c",
        "import os,sys,subprocess,pathlib; root=os.environ.get('AGENT_OS_ROOT') or str(pathlib.Path.home()/'.ai-os'); subprocess.run([sys.executable, str(pathlib.Path(root)/'scripts'/'graphify_mcp_wrapper.py')])"
      ]
    }
  },
  "alwaysAllow": {
    "tools": ["Read", "grep", "Glob", "view"],
    "mcpTools": ["context7-get-library-docs", "graphify-query", "query_rules", "check_policy", "search_memory", "search_memory_vector"]
  }
}
